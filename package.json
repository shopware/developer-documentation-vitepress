{
  "name": "vitepress-shopware-docs",
  "version": "1.3.6",
  "description": "Vitepress theme for Shopware",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./highlight": "./src/shopware/config/highlight.js",
    "./src/*.css": {
      "import": "./src/*.css",
      "require": "./src/*.css"
    },
    "./src/*.scss": {
      "import": "./src/*.scss",
      "require": "./src/*.scss"
    }
  },
  "files": [
    "src",
    "types"
  ],
  "keywords": [
    "vue",
    "shopware",
    "vitepress"
  ],
  "author": {
    "name": "Shopware team"
  },
  "license": "MIT",
  "scripts": {
    "lint:full": "pnpm run lint && pnpm run type",
    "lint": "prettier --check --write --parser typescript \"{__tests__,docs,src,types}/**/*.ts\"",
    "lint:fail": "prettier --check --parser typescript \"{__tests__,docs,src,types}/**/*.ts\"",
    "type": "tsc --noEmit",
    "test:unit": "vitest run -r __tests__/unit --sequence.shuffle",
    "test:cli": "vitest run -r __tests__/cli --sequence.shuffle",
    "test:cli:coverage": "vitest run -r __tests__/cli --coverage",
    "dev": "vitepress dev demo",
    "build": "vitepress build demo",
    "serve": "pnpm run build && vitepress serve demo --port 5002",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "npx chromatic --exit-zero-on-changes",
    "bump": "npx lerna version --no-private --no-push",
    "cli:dev": "pnpm -C ./packages/cli dev && chmod +x ./packages/cli/dist/docs-cli.js",
    "cli:build": "pnpm -C ./packages/cli build && chmod +x ./packages/cli/dist/docs-cli.js",
    "cli:pkg": "pnpm -C ./packages/cli pkg"
  },
  "dependencies": {
    "@iconify-json/carbon": "^1.2.20",
    "@shopware-ag/meteor-icon-kit": "^5.6.0",
    "@stoplight/elements-dev-portal": "^3.0.19",
    "@stoplight/json-schema-generator": "^1.0.2",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.15.2",
    "body-scroll-lock": "^3.1.5",
    "fs-extra": "^11.3.4",
    "fsevents": "^2.3.3",
    "gray-matter": "^4.0.3",
    "medium-zoom": "^1.1.0",
    "normalize.css": "^8.0.1",
    "semver": "^7.7.4",
    "shiki": "^4.0.2",
    "unocss": "^66.6.8"
  },
  "peerDependencies": {
    "@docsearch/css": "^3.5.2",
    "@docsearch/js": "^3.5.2",
    "algoliasearch": "^4.20.0",
    "instantsearch.css": "^8.5.1",
    "instantsearch.js": "^4.74.2",
    "vue-instantsearch": "^4.19.5"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^10.3.5",
    "@storybook/addon-styling": "^1.3.7",
    "@storybook/blocks": "^8.6.14",
    "@storybook/testing-library": "^0.2.2",
    "@storybook/vue3": "^10.3.5",
    "@storybook/vue3-vite": "^10.3.5",
    "@types/body-scroll-lock": "^3.1.2",
    "@types/estree": "^1.0.8",
    "@types/fs-extra": "^11.0.4",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.6.0",
    "@types/remove-markdown": "^0.3.4",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vueuse/shared": "14.2.1",
    "chromatic": "^16.6.0",
    "esbuild": "^0.28.0",
    "get-port": "^7.2.0",
    "google-fonts-helper": "^3.7.4",
    "lerna": "^9.0.7",
    "lorem-ipsum": "^2.0.8",
    "playwright-chromium": "^1.59.1",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remove-markdown": "^0.6.3",
    "sass": "^1.99.0",
    "seedrandom": "^3.0.5",
    "storybook": "^10.3.5",
    "storybook-addon-fetch-mock": "^2.0.1",
    "storybook-addon-pseudo-states": "^10.3.5",
    "terser": "^5.46.2",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vitepress": "1.6.4",
    "vitest": "^3.2.4",
    "vue": "^3.5.33"
  },
  "engines": {
    "node": ">=24.6.0"
  },
  "packageManager": "pnpm@10.17.0",
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@algolia/client-search",
        "react",
        "react-dom",
        "vite",
        "@types/react",
        "mkdirp",
        "@stoplight/mosaic-code-viewer"
      ]
    }
  }
}
